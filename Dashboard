<!DOCTYPE html>
<html lang="en-GB">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mostlane · Van Checks</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --brand: #04579d;
    --brand-hover: #023e72;
    --brand-soft: #e8f1fb;
    --brand-50: #f2f7fc;

    --bg: #f6f8fb;
    --surface: #ffffff;
    --surface-raised: #ffffff;

    --ink: #0a1628;
    --ink-2: #334155;
    --ink-3: #64748b;
    --ink-4: #94a3b8;

    --border: #e2e8f0;
    --border-strong: #cbd5e1;

    --ok: #10b981;
    --ok-bg: #d1fae5;
    --ok-ink: #065f46;
    --warn: #f59e0b;
    --warn-bg: #fef3c7;
    --warn-ink: #92400e;
    --alert: #ef4444;
    --alert-bg: #fee2e2;
    --alert-ink: #991b1b;

    --r-xs: 8px;
    --r-sm: 12px;
    --r-md: 16px;
    --r-lg: 20px;
    --r-xl: 28px;
    --r-full: 999px;

    --shadow-sm: 0 1px 2px rgba(10, 22, 40, 0.04), 0 1px 3px rgba(10, 22, 40, 0.04);
    --shadow-md: 0 4px 12px rgba(10, 22, 40, 0.06), 0 2px 4px rgba(10, 22, 40, 0.04);
    --shadow-lg: 0 16px 40px rgba(10, 22, 40, 0.08), 0 4px 12px rgba(10, 22, 40, 0.04);

    --font: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --font-mono: 'JetBrains Mono', 'SF Mono', Consolas, monospace;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  html, body { background: var(--bg); }

  body {
    font-family: var(--font);
    color: var(--ink);
    font-size: 14px;
    line-height: 1.55;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    padding: 24px 28px 80px;
    max-width: 1300px;
    margin: 0 auto;
    min-height: 100vh;
    background-image:
      radial-gradient(ellipse 800px 400px at 0% 0%, rgba(4, 87, 157, 0.05) 0%, transparent 60%),
      radial-gradient(ellipse 600px 300px at 100% 10%, rgba(16, 185, 129, 0.03) 0%, transparent 60%);
  }

  /* ───────── Header ───────── */
  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 4px 8px 20px;
    gap: 20px;
    flex-wrap: wrap;
  }
  .header-left { display: flex; align-items: center; gap: 14px; }
  .brand-logo { height: 38px; width: auto; display: block; }
  .header-divider {
    width: 1px;
    height: 28px;
    background: var(--border);
  }
  .app-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--ink);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .app-title .emoji { font-size: 20px; }

  .header-right {
    display: flex;
    align-items: center;
    gap: 14px;
    font-size: 13px;
  }
  .week-chip {
    background: var(--surface);
    padding: 8px 14px;
    border-radius: var(--r-full);
    box-shadow: var(--shadow-sm);
    font-weight: 600;
    color: var(--ink-2);
    display: flex;
    align-items: center;
    gap: 8px;
    border: 1px solid var(--border);
  }
  .week-chip .dot {
    width: 8px;
    height: 8px;
    background: var(--ok);
    border-radius: 50%;
    box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.15);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.15); }
    50% { box-shadow: 0 0 0 6px rgba(16, 185, 129, 0.05); }
  }
  .stamp {
    color: var(--ink-4);
    font-size: 12px;
    font-variant-numeric: tabular-nums;
  }

  /* ───────── Nav pills ───────── */
  .nav {
    display: flex;
    gap: 6px;
    padding: 6px;
    background: var(--surface);
    border-radius: var(--r-full);
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--border);
    margin-bottom: 24px;
    width: fit-content;
    overflow-x: auto;
  }
  .tab {
    padding: 8px 18px;
    font-size: 13.5px;
    font-weight: 600;
    color: var(--ink-3);
    background: transparent;
    border: none;
    border-radius: var(--r-full);
    cursor: pointer;
    font-family: var(--font);
    transition: all 200ms cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    align-items: center;
    gap: 7px;
    white-space: nowrap;
  }
  .tab:hover { color: var(--ink); background: var(--brand-50); }
  .tab.active {
    background: var(--brand);
    color: white;
    box-shadow: 0 2px 8px rgba(4, 87, 157, 0.3);
  }
  .tab.active:hover { background: var(--brand); }

  .view { display: none; animation: fadeIn 300ms cubic-bezier(0.4, 0, 0.2, 1); }
  .view.active { display: block; }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: none; }
  }

  /* ───────── Toolbar ───────── */
  .toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
    margin-bottom: 20px;
  }
  .chip-select {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-full);
    padding: 8px 16px;
    box-shadow: var(--shadow-sm);
    display: flex;
    align-items: center;
    gap: 8px;
    transition: all 150ms ease;
  }
  .chip-select:hover { border-color: var(--border-strong); box-shadow: var(--shadow-md); }
  .chip-select:focus-within { border-color: var(--brand); box-shadow: 0 0 0 3px rgba(4, 87, 157, 0.12); }
  .chip-select label {
    font-size: 12px;
    font-weight: 500;
    color: var(--ink-3);
  }
  .chip-select select, .chip-select input {
    border: none;
    background: transparent;
    font-family: var(--font);
    font-size: 13px;
    font-weight: 600;
    color: var(--ink);
    outline: none;
    cursor: pointer;
    min-width: 80px;
  }
  .chip-select input { cursor: text; min-width: 220px; }

  .spacer { flex: 1; }

  button {
    font-family: var(--font);
    font-size: 13px;
    font-weight: 600;
    padding: 9px 18px;
    border-radius: var(--r-full);
    border: none;
    background: var(--brand);
    color: white;
    cursor: pointer;
    transition: all 180ms cubic-bezier(0.4, 0, 0.2, 1);
    display: inline-flex;
    align-items: center;
    gap: 7px;
    box-shadow: 0 2px 8px rgba(4, 87, 157, 0.25);
  }
  button:hover { background: var(--brand-hover); transform: translateY(-1px); box-shadow: 0 4px 12px rgba(4, 87, 157, 0.3); }
  button:active { transform: translateY(0); }
  button:disabled { opacity: 0.45; cursor: not-allowed; transform: none; }
  button.ghost {
    background: var(--surface);
    color: var(--ink);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-sm);
  }
  button.ghost:hover { background: var(--brand-50); border-color: var(--border-strong); color: var(--ink); box-shadow: var(--shadow-md); }
  button.danger-ghost {
    background: var(--surface);
    color: var(--alert-ink);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-sm);
  }
  button.danger-ghost:hover { background: var(--alert-bg); border-color: var(--alert); }
  button.small { padding: 6px 12px; font-size: 12px; border-radius: var(--r-full); }

  /* ───────── Stats ───────── */
  .stats {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 14px;
    margin-bottom: 24px;
  }
  .stat {
    background: var(--surface);
    padding: 20px 22px;
    border-radius: var(--r-lg);
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--border);
    transition: all 200ms cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }
  .stat:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }
  .stat-top {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 10px;
  }
  .stat-emoji {
    width: 36px;
    height: 36px;
    border-radius: var(--r-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
  }
  .stat-label {
    font-size: 12px;
    font-weight: 600;
    color: var(--ink-3);
  }
  .stat-num {
    font-size: 34px;
    font-weight: 700;
    color: var(--ink);
    line-height: 1;
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.02em;
  }
  .stat-sub {
    font-size: 12px;
    color: var(--ink-4);
    margin-top: 6px;
  }

  .stat.s-total .stat-emoji { background: var(--brand-soft); }
  .stat.s-done .stat-emoji { background: var(--ok-bg); }
  .stat.s-done .stat-num { color: var(--ok); }
  .stat.s-warn .stat-emoji { background: var(--warn-bg); }
  .stat.s-warn .stat-num { color: var(--warn-ink); }
  .stat.s-alert .stat-emoji { background: var(--alert-bg); }
  .stat.s-alert .stat-num { color: var(--alert); }
  .stat.s-unknown .stat-emoji { background: #f3e8ff; }
  .stat.s-unknown .stat-num { color: #7c3aed; }

  /* ───────── Card/Panel ───────── */
  .card {
    background: var(--surface);
    border-radius: var(--r-lg);
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--border);
    overflow: hidden;
    margin-bottom: 20px;
  }
  .card-header {
    padding: 18px 22px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
    border-bottom: 1px solid var(--border);
  }
  .card-header h2 {
    font-size: 16px;
    font-weight: 700;
    color: var(--ink);
    display: flex;
    align-items: center;
    gap: 8px;
    letter-spacing: -0.01em;
  }
  .card-header .meta {
    font-size: 12px;
    color: var(--ink-3);
    font-weight: 500;
  }
  .card-body { padding: 18px 22px; }

  /* ───────── Table as cards ───────── */
  table { width: 100%; border-collapse: collapse; font-variant-numeric: tabular-nums; }
  th {
    text-align: left;
    padding: 12px 22px;
    font-size: 11.5px;
    font-weight: 600;
    color: var(--ink-3);
    background: #fafbfd;
    border-bottom: 1px solid var(--border);
    letter-spacing: 0.02em;
  }
  td {
    padding: 16px 22px;
    border-bottom: 1px solid var(--border);
    font-size: 14px;
    vertical-align: middle;
  }
  tr:last-child td { border-bottom: none; }
  tr.clickable { cursor: pointer; transition: background 120ms ease; }
  tr.clickable:hover { background: var(--brand-50); }
  tr.row-done { background: linear-gradient(90deg, rgba(16, 185, 129, 0.04) 0%, transparent 30%); }

  /* ───────── Status bubbles ───────── */
  .status {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 12px;
    font-size: 12px;
    font-weight: 600;
    border-radius: var(--r-full);
    white-space: nowrap;
  }
  .status.done { background: var(--ok-bg); color: var(--ok-ink); }
  .status.missing { background: var(--alert-bg); color: var(--alert-ink); }
  .status.overdue { background: var(--warn-bg); color: var(--warn-ink); }

  /* ───────── Number plate ───────── */
  .reg {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 1.5px;
    background: #ffd631;
    color: #1a1a1a;
    padding: 5px 11px 4px;
    border-radius: var(--r-xs);
    display: inline-block;
    white-space: nowrap;
    line-height: 1;
    border: 1.5px solid #1a1a1a;
    box-shadow: 0 1px 2px rgba(0,0,0,0.1);
  }

  .engineer-name {
    font-weight: 600;
    color: var(--ink);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--brand-soft);
    color: var(--brand);
    font-size: 11px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    letter-spacing: 0;
  }
  .engineer-sub { font-size: 12px; color: var(--ink-4); margin-top: 3px; margin-left: 36px; }
  .mileage {
    color: var(--ink-2);
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 600;
  }
  .timestamp {
    color: var(--ink-3);
    font-size: 12.5px;
    font-weight: 500;
  }
  .flag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--alert-ink);
    background: var(--alert-bg);
    padding: 4px 10px;
    border-radius: var(--r-full);
    font-size: 12px;
    font-weight: 600;
  }
  .flag-detail {
    color: var(--ink-3);
    font-size: 12.5px;
    margin-top: 6px;
    line-height: 1.5;
    max-width: 280px;
  }
  .dash { color: var(--ink-4); }

  /* ───────── Banner ───────── */
  .banner {
    background: linear-gradient(135deg, var(--warn-bg) 0%, #fef9c3 100%);
    border: 1px solid #fde68a;
    color: var(--warn-ink);
    padding: 14px 18px;
    margin-bottom: 20px;
    font-size: 13.5px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 14px;
    border-radius: var(--r-md);
    box-shadow: var(--shadow-sm);
  }
  .banner-left { display: flex; align-items: center; gap: 12px; }
  .banner-emoji { font-size: 20px; flex-shrink: 0; }

  /* ───────── Empty / loading ───────── */
  .empty, .loading {
    padding: 56px 20px;
    text-align: center;
    color: var(--ink-3);
    font-size: 14px;
  }
  .empty-emoji { font-size: 40px; display: block; margin-bottom: 12px; }
  .error {
    background: var(--alert-bg);
    color: var(--alert-ink);
    border: 1px solid #fecaca;
    padding: 14px 18px;
    margin: 16px 22px;
    font-size: 13.5px;
    border-radius: var(--r-md);
    display: flex;
    align-items: center;
    gap: 10px;
  }

  /* ───────── Alias tags ───────── */
  .alias-tag {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: var(--brand-50);
    border: 1px solid var(--brand-soft);
    padding: 3px 4px 3px 11px;
    border-radius: var(--r-full);
    font-size: 12px;
    margin: 3px 5px 3px 0;
    color: var(--brand);
    font-weight: 500;
  }
  .alias-tag .x {
    color: var(--ink-4);
    cursor: pointer;
    padding: 2px 7px;
    border-radius: var(--r-full);
    font-size: 13px;
    line-height: 1;
    transition: all 120ms ease;
  }
  .alias-tag .x:hover { color: var(--alert); background: var(--alert-bg); }

  /* ───────── Engineer card ───────── */
  .engineer-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    padding: 16px 22px;
    border-bottom: 1px solid var(--border);
    transition: background 120ms ease;
  }
  .engineer-row:last-child { border-bottom: none; }
  .engineer-row:hover { background: var(--brand-50); }
  .engineer-row-left { display: flex; align-items: center; gap: 14px; flex: 1; min-width: 0; }
  .avatar-lg {
    width: 44px;
    height: 44px;
    font-size: 15px;
    flex-shrink: 0;
  }
  .engineer-name-lg { font-size: 15px; font-weight: 700; color: var(--ink); }
  .engineer-meta { font-size: 12px; color: var(--ink-3); margin-top: 2px; }
  .engineer-aliases { margin-top: 6px; }
  .engineer-actions { display: flex; gap: 6px; flex-shrink: 0; }

  /* ───────── History ───────── */
  .history-item {
    display: grid;
    grid-template-columns: 44px 1fr auto;
    gap: 14px;
    padding: 14px 22px;
    border-bottom: 1px solid var(--border);
    align-items: flex-start;
    transition: background 120ms ease;
  }
  .history-item:last-child { border-bottom: none; }
  .history-item:hover { background: #fafbfd; }
  .history-avatar { width: 36px; height: 36px; font-size: 13px; }
  .history-main .engineer-name-lg { font-size: 14px; }
  .history-meta {
    display: flex;
    gap: 10px;
    align-items: center;
    flex-wrap: wrap;
    margin-top: 4px;
    font-size: 12.5px;
    color: var(--ink-3);
  }
  .history-right {
    text-align: right;
    font-size: 12px;
    color: var(--ink-3);
    font-weight: 500;
  }

  /* ───────── Modal ───────── */
  .modal-backdrop {
    position: fixed; inset: 0;
    background: rgba(10, 22, 40, 0.45);
    backdrop-filter: blur(8px);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 100;
    padding: 20px;
    animation: fadeIn 200ms ease-out;
  }
  .modal-backdrop.open { display: flex; }
  .modal {
    background: var(--surface);
    border-radius: var(--r-xl);
    max-width: 540px;
    width: 100%;
    max-height: 90vh;
    overflow-y: auto;
    box-shadow: var(--shadow-lg);
    animation: modalIn 220ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  @keyframes modalIn {
    from { opacity: 0; transform: translateY(10px) scale(0.98); }
    to { opacity: 1; transform: none; }
  }
  .modal-header {
    padding: 22px 26px 16px;
    font-size: 17px;
    font-weight: 700;
    color: var(--ink);
    letter-spacing: -0.01em;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .modal-body { padding: 0 26px 22px; }
  .modal-footer {
    padding: 16px 26px 20px;
    display: flex;
    gap: 10px;
    justify-content: flex-end;
    border-top: 1px solid var(--border);
    background: #fafbfd;
    border-radius: 0 0 var(--r-xl) var(--r-xl);
  }

  .modal-field { margin-bottom: 14px; }
  .modal-field label {
    display: block;
    font-size: 12px;
    font-weight: 600;
    color: var(--ink-2);
    margin-bottom: 6px;
  }
  .modal-field input, .modal-field select {
    width: 100%;
    padding: 10px 14px;
    border: 1px solid var(--border);
    border-radius: var(--r-sm);
    font-size: 14px;
    font-family: var(--font);
    background: var(--surface);
    color: var(--ink);
    transition: all 150ms ease;
  }
  .modal-field input:focus, .modal-field select:focus {
    outline: none;
    border-color: var(--brand);
    box-shadow: 0 0 0 3px rgba(4, 87, 157, 0.12);
  }
  .modal-intro {
    font-size: 13px;
    color: var(--ink-3);
    margin-bottom: 14px;
    line-height: 1.55;
  }

  .resolve-item {
    padding: 14px 0;
    border-top: 1px solid var(--border);
  }
  .resolve-item:first-child { border-top: none; padding-top: 0; }
  .resolve-item .unknown-name {
    font-size: 15px;
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--ink);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .resolve-item .suggestion {
    font-size: 12px;
    color: var(--ink-3);
    margin-top: 6px;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  /* ───────── Responsive ───────── */
  @media (max-width: 900px) {
    body { padding: 18px 16px 60px; }
    .stats { grid-template-columns: repeat(2, 1fr); }
    .stats .stat:last-child:nth-child(odd) { grid-column: 1 / -1; }
  }
  @media (max-width: 640px) {
    .header { flex-direction: column; align-items: flex-start; }
    .toolbar { flex-direction: column; align-items: stretch; }
    .chip-select { width: 100%; }
    .chip-select input { min-width: 0; width: 100%; }
    th:nth-child(4), td:nth-child(4) { display: none; }
    .history-item { grid-template-columns: 36px 1fr; }
    .history-right { grid-column: 2 / -1; text-align: left; margin-top: 4px; }
  }
</style>
</head>
<body>

<header class="header">
  <div class="header-left">
    <img class="brand-logo" src="/logo.png" alt="Mostlane">
    <div class="header-divider"></div>
    <div class="app-title"><span class="emoji">🚐</span> Van Checks</div>
  </div>
  <div class="header-right">
    <div class="week-chip"><span class="dot"></span><span id="weekLabel">—</span></div>
    <div class="stamp" id="lastRefresh">Loading…</div>
  </div>
</header>

<nav class="nav">
  <button class="tab active" data-view="current">📋 This Week</button>
  <button class="tab" data-view="history">📚 History</button>
  <button class="tab" data-view="engineers">👷 Engineers</button>
  <button class="tab" data-view="fleet">🚐 Fleet</button>
</nav>

<!-- ═══════ This Week ═══════ -->
<div class="view active" id="view-current">
  <div class="toolbar">
    <div class="chip-select">
      <label>📅 Week begins</label>
      <select id="cutoffDay">
