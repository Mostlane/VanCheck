<!DOCTYPE html>
<html lang="en-GB">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mostlane · Fleet Compliance</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet">
<style>
  :root {
    --ml-blue: #04579d;
    --ml-blue-dark: #023e72;
    --ml-blue-soft: #e8f0f9;
    --paper: #fbfaf7;
    --card: #ffffff;
    --ink: #0f1724;
    --ink-muted: #52606d;
    --ink-soft: #8a95a3;
    --rule: #e8e3d8;
    --rule-strong: #d4cfc2;
    --ok: #2a6b3f;
    --ok-soft: #eef5ef;
    --warn: #8a5a0b;
    --warn-soft: #f9f1e1;
    --alert: #8c2020;
    --alert-soft: #f6ebeb;
    --font-display: 'Fraunces', 'Times New Roman', serif;
    --font-body: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    --font-mono: 'JetBrains Mono', 'SF Mono', Consolas, monospace;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { background: var(--paper); }
  body {
    font-family: var(--font-body);
    color: var(--ink);
    font-size: 14px;
    line-height: 1.55;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    padding: 32px 40px 80px;
    max-width: 1320px;
    margin: 0 auto;
    background-image:
      radial-gradient(circle at 10% 0%, rgba(4, 87, 157, 0.03) 0%, transparent 40%),
      radial-gradient(circle at 90% 100%, rgba(4, 87, 157, 0.02) 0%, transparent 40%);
    min-height: 100vh;
  }

  .masthead {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: end;
    gap: 24px;
    padding-bottom: 20px;
    margin-bottom: 32px;
    border-bottom: 1px solid var(--rule);
    position: relative;
  }
  .masthead::after {
    content: ''; position: absolute; bottom: -3px; left: 0;
    width: 120px; height: 2px; background: var(--ml-blue);
  }
  .brand-logo { height: 44px; width: auto; display: block; }
  .masthead-centre { padding-bottom: 2px; }
  .eyebrow {
    font-family: var(--font-body);
    font-size: 10px; font-weight: 600; letter-spacing: 2.4px;
    text-transform: uppercase; color: var(--ml-blue); margin-bottom: 6px;
  }
  .masthead h1 {
    font-family: var(--font-display);
    font-weight: 500; font-size: 26px; letter-spacing: -0.01em;
    color: var(--ink); line-height: 1.1;
    font-variation-settings: "opsz" 48;
  }
  .masthead-meta { text-align: right; padding-bottom: 4px; }
  .masthead-meta .week {
    font-family: var(--font-display);
    font-size: 16px; font-weight: 500; color: var(--ink);
    font-variation-settings: "opsz" 24;
  }
  .masthead-meta .stamp {
    font-size: 11px; color: var(--ink-soft); margin-top: 2px;
    font-variant-numeric: tabular-nums; letter-spacing: 0.02em;
  }

  .nav {
    display: flex; gap: 0; margin-bottom: 28px;
    border-bottom: 1px solid var(--rule);
  }
  .tab {
    padding: 10px 20px 12px;
    font-size: 12px; font-weight: 600; letter-spacing: 1.2px;
    text-transform: uppercase; color: var(--ink-soft);
    background: transparent; border: none;
    border-bottom: 2px solid transparent; margin-bottom: -1px;
    cursor: pointer; font-family: var(--font-body);
    transition: color 150ms ease, border-color 150ms ease;
  }
  .tab:hover { color: var(--ink); }
  .tab.active { color: var(--ml-blue); border-bottom-color: var(--ml-blue); }

  .view { display: none; animation: fadeIn 250ms ease-out; }
  .view.active { display: block; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: none; } }

  .toolbar {
    display: flex; flex-wrap: wrap; gap: 20px; align-items: flex-end;
    padding: 16px 20px; background: var(--card);
    border: 1px solid var(--rule); border-radius: 2px; margin-bottom: 20px;
  }
  .field { display: flex; flex-direction: column; gap: 5px; }
  .field label {
    font-size: 10px; font-weight: 600; color: var(--ink-soft);
    text-transform: uppercase; letter-spacing: 1.4px;
  }
  .field input, .field select {
    padding: 8px 12px; border: 1px solid var(--rule-strong);
    border-radius: 2px; font-size: 13px; font-family: var(--font-body);
    background: var(--card); color: var(--ink); min-width: 180px;
    transition: border-color 150ms ease;
  }
  .field input:focus, .field select:focus {
    outline: none; border-color: var(--ml-blue);
    box-shadow: 0 0 0 3px rgba(4, 87, 157, 0.1);
  }
  .toolbar-spacer { flex: 1; }

  button {
    font-family: var(--font-body); font-size: 12px; font-weight: 600;
    letter-spacing: 0.6px; padding: 9px 18px; border-radius: 2px;
    border: 1px solid var(--ml-blue); background: var(--ml-blue);
    color: white; cursor: pointer;
    transition: background 150ms ease, border-color 150ms ease;
    text-transform: uppercase;
  }
  button:hover { background: var(--ml-blue-dark); border-color: var(--ml-blue-dark); }
  button:disabled { opacity: 0.45; cursor: not-allowed; }
  button.ghost { background: var(--card); color: var(--ink); border-color: var(--rule-strong); }
  button.ghost:hover { background: var(--paper); border-color: var(--ink-soft); color: var(--ink); }
  button.danger-ghost { background: var(--card); color: var(--alert); border-color: var(--rule-strong); }
  button.danger-ghost:hover { background: var(--alert-soft); border-color: var(--alert); }
  button.small { padding: 5px 10px; font-size: 10px; letter-spacing: 0.5px; }

  .stats {
    display: grid; grid-template-columns: repeat(5, 1fr); gap: 0;
    margin-bottom: 28px; background: var(--card);
    border: 1px solid var(--rule); border-radius: 2px; overflow: hidden;
  }
  .stat { padding: 20px 22px; border-right: 1px solid var(--rule); }
  .stat:last-child { border-right: none; }
  .stat .stat-label {
    font-size: 10px; font-weight: 600; color: var(--ink-soft);
    text-transform: uppercase; letter-spacing: 1.4px; margin-bottom: 10px;
  }
  .stat .stat-num {
    font-family: var(--font-display); font-weight: 500; font-size: 38px;
    line-height: 1; color: var(--ink); font-variant-numeric: tabular-nums;
    font-variation-settings: "opsz" 72; letter-spacing: -0.02em;
  }
  .stat .stat-sub {
    font-size: 11px; color: var(--ink-soft); margin-top: 6px;
    font-style: italic; font-family: var(--font-display);
    font-variation-settings: "opsz" 12;
  }
  .stat.accent-done .stat-num { color: var(--ok); }
  .stat.accent-warn .stat-num { color: var(--warn); }
  .stat.accent-alert .stat-num { color: var(--alert); }

  .panel {
    background: var(--card); border: 1px solid var(--rule);
    border-radius: 2px; margin-bottom: 20px; overflow: hidden;
  }
  .panel-header {
    padding: 16px 24px; border-bottom: 1px solid var(--rule);
    display: flex; justify-content: space-between; align-items: baseline;
    flex-wrap: wrap; gap: 10px;
  }
  .panel-header h2 {
    font-family: var(--font-display); font-weight: 500; font-size: 18px;
    color: var(--ink); letter-spacing: -0.005em;
    font-variation-settings: "opsz" 24;
  }
  .panel-header .meta {
    font-size: 11px; color: var(--ink-soft);
    text-transform: uppercase; letter-spacing: 1.2px; font-weight: 600;
  }
  .panel-body { padding: 20px 24px; }

  table { width: 100%; border-collapse: collapse; font-variant-numeric: tabular-nums; }
  th {
    text-align: left; padding: 10px 24px;
    font-size: 10px; font-weight: 600; text-transform: uppercase;
    letter-spacing: 1.4px; color: var(--ink-soft);
    background: var(--paper); border-bottom: 1px solid var(--rule);
  }
  td {
    padding: 16px 24px; border-bottom: 1px solid var(--rule);
    font-size: 13.5px; vertical-align: middle;
  }
  tr:last-child td { border-bottom: none; }
  tr.row-done { background: linear-gradient(to right, rgba(42, 107, 63, 0.025) 0%, transparent 8%); }
  tr.row-overdue td:first-child { box-shadow: inset 3px 0 0 var(--warn); }
  tr.row-missing td:first-child { box-shadow: inset 3px 0 0 var(--alert); }
  tr.row-done td:first-child { box-shadow: inset 3px 0 0 var(--ok); }
  tr.clickable { cursor: pointer; transition: background 120ms ease; }
  tr.clickable:hover { background: var(--paper); }

  .status {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 3px 10px 4px; font-size: 10.5px; font-weight: 600;
    text-transform: uppercase; letter-spacing: 1px; white-space: nowrap;
    border-radius: 2px; border: 1px solid transparent;
  }
  .status::before { content: ''; width: 6px; height: 6px; border-radius: 50%; display: inline-block; }
  .status.done { background: var(--ok-soft); color: var(--ok); border-color: rgba(42, 107, 63, 0.2); }
  .status.done::before { background: var(--ok); }
  .status.missing { background: var(--alert-soft); color: var(--alert); border-color: rgba(140, 32, 32, 0.2); }
  .status.missing::before { background: var(--alert); }
  .status.overdue { background: var(--warn-soft); color: var(--warn); border-color: rgba(138, 90, 11, 0.2); }
  .status.overdue::before { background: var(--warn); }

  .reg {
    font-family: var(--font-mono); font-weight: 700; font-size: 12.5px;
    letter-spacing: 1.5px; background: var(--ink); color: #f8d03e;
    padding: 4px 9px 3px; border-radius: 2px; display: inline-block;
    white-space: nowrap; line-height: 1;
  }
  .engineer-name { font-weight: 500; color: var(--ink); }
  .engineer-sub { font-size: 11.5px; color: var(--ink-soft); margin-top: 3px; }
  .mileage { color: var(--ink-muted); font-family: var(--font-mono); font-size: 12.5px; font-weight: 500; }
  .timestamp { font-family: var(--font-mono); font-size: 12px; color: var(--ink-muted); font-weight: 500; }
  .flag { display: inline-flex; align-items: center; gap: 6px; color: var(--alert); font-size: 12.5px; font-weight: 600; }
  .flag-detail {
    color: var(--ink-muted); font-size: 12px; margin-top: 4px;
    font-style: italic; line-height: 1.4; font-family: var(--font-display);
    font-variation-settings: "opsz" 14;
  }
  .dash { color: var(--ink-soft); }

  .alias-tag {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--paper); border: 1px solid var(--rule);
    padding: 3px 4px 3px 10px; border-radius: 2px;
    font-size: 11.5px; margin-right: 5px; margin-top: 4px;
    color: var(--ink-muted); font-family: var(--font-mono); font-weight: 500;
  }
  .alias-tag .x { color: var(--ink-soft); cursor: pointer; padding: 0 5px; font-size: 14px; line-height: 1; }
  .alias-tag .x:hover { color: var(--alert); }

  .empty, .loading {
    padding: 56px 20px; text-align: center; color: var(--ink-soft);
    font-family: var(--font-display); font-style: italic;
    font-size: 15px; font-variation-settings: "opsz" 18;
  }
  .error {
    color: var(--alert); background: var(--alert-soft);
    border-left: 3px solid var(--alert);
    padding: 14px 18px; margin: 0 24px 20px;
    font-size: 13px; border-radius: 2px;
  }
  .banner {
    background: var(--warn-soft); border-left: 3px solid var(--warn);
    color: var(--ink); padding: 14px 18px; margin-bottom: 20px;
    font-size: 13.5px; display: flex; justify-content: space-between;
    align-items: center; gap: 14px; border-radius: 2px;
  }
  .banner strong { color: var(--warn); font-weight: 600; }

  .engineer-card {
    border: 1px solid var(--rule); border-radius: 2px;
    padding: 18px 22px; margin-bottom: 12px; background: var(--card);
    transition: border-color 150ms ease;
  }
  .engineer-card:hover { border-color: var(--rule-strong); }
  .engineer-card-top { display: flex; justify-content: space-between; align-items: flex-start; gap: 14px; }
  .engineer-card .name {
    font-family: var(--font-display); font-weight: 500; font-size: 18px;
    color: var(--ink); margin-bottom: 2px; letter-spacing: -0.005em;
    font-variation-settings: "opsz" 24;
  }
  .engineer-card .meta {
    font-size: 11px; color: var(--ink-soft);
    text-transform: uppercase; letter-spacing: 1px; font-weight: 600;
  }
  .engineer-card .btn-group { display: flex; flex-direction: column; gap: 6px; }

  .history-row {
    padding: 16px 24px; border-bottom: 1px solid var(--rule);
    display: grid; grid-template-columns: 130px 1fr auto;
    gap: 20px; align-items: baseline;
  }
  .history-row:last-child { border-bottom: none; }
  .history-row .when { font-family: var(--font-mono); font-size: 11.5px; color: var(--ink-muted); font-weight: 500; }
  .history-row .what .engineer-name { font-size: 14.5px; }
  .history-row .what .sub-meta {
    margin-top: 4px; font-size: 12px; color: var(--ink-muted);
    display: flex; gap: 10px; align-items: center; flex-wrap: wrap;
  }

  .modal-backdrop {
    position: fixed; inset: 0;
    background: rgba(15, 23, 36, 0.5); backdrop-filter: blur(4px);
    display: none; align-items: center; justify-content: center;
    z-index: 100; padding: 20px;
    animation: fadeIn 200ms ease-out;
  }
  .modal-backdrop.open { display: flex; }
  .modal {
    background: var(--card); border-radius: 2px;
    max-width: 540px; width: 100%;
    max-height: 90vh; overflow-y: auto;
    border: 1px solid var(--rule);
    box-shadow: 0 32px 80px -24px rgba(15, 23, 36, 0.3);
  }
  .modal-header {
    padding: 20px 26px 18px; border-bottom: 1px solid var(--rule);
    font-family: var(--font-display); font-weight: 500; font-size: 19px;
    color: var(--ink); letter-spacing: -0.005em;
    font-variation-settings: "opsz" 24;
  }
  .modal-body { padding: 22px 26px; }
  .modal-footer {
    padding: 16px 26px; border-top: 1px solid var(--rule);
    background: var(--paper);
    display: flex; gap: 10px; justify-content: flex-end;
  }
  .modal .field { margin-bottom: 16px; }
  .modal .field input, .modal .field select { width: 100%; }
  .modal-intro { font-size: 13px; color: var(--ink-muted); margin-bottom: 14px; line-height: 1.55; }

  .resolve-item { padding: 14px 0; border-top: 1px solid var(--rule); }
  .resolve-item:first-child { border-top: none; padding-top: 0; }
  .resolve-item .unknown-name {
    font-family: var(--font-display); font-weight: 500; font-size: 16px;
    margin-bottom: 8px; color: var(--ink);
    font-variation-settings: "opsz" 20;
  }
  .resolve-item .suggestion {
    font-size: 11.5px; color: var(--ink-muted);
    margin-top: 6px; font-style: italic;
  }

  @media (max-width: 900px) {
    body { padding: 20px 16px 60px; }
    .stats { grid-template-columns: repeat(2, 1fr); }
    .stat { border-right: 1px solid var(--rule); border-bottom: 1px solid var(--rule); }
    .stat:nth-child(2n) { border-right: none; }
    .stat:nth-last-child(-n+2) { border-bottom: none; }
    .stat:last-child:nth-child(odd) { grid-column: 1 / -1; border-right: none; }
  }
  @media (max-width: 640px) {
    .masthead { grid-template-columns: 1fr; gap: 12px; }
    .masthead-meta { text-align: left; }
    .toolbar { flex-direction: column; align-items: stretch; }
    .field input, .field select { min-width: 0; width: 100%; }
    th:nth-child(4), td:nth-child(4) { display: none; }
    .history-row { grid-template-columns: 1fr; gap: 6px; }
  }
</style>
</head>
<body>

<header class="masthead">
  <img class="brand-logo" src="data:image/png;base64," alt="Mostlane">
  <div class="masthead-centre">
    <div class="eyebrow">Fleet Compliance</div>
    <h1>Weekly Van Check Register</h1>
  </div>
  <div class="masthead-meta">
    <div class="week" id="weekLabel">—</div>
    <div class="stamp" id="lastRefresh">Loading…</div>
  </div>
</header>

<nav class="nav">
  <button class="tab active" data-view="current">This Week</button>
  <button class="tab" data-view="history">History</button>
  <button class="tab" data-view="engineers">Engineers</button>
  <button class="tab" data-view="fleet">Fleet</button>
</nav>

<div class="view active" id="view-current">
  <div class="toolbar">
    <div class="field">
      <label>Week begins</label>
      <select id="cutoffDay">
        <option value="1">Monday</option>
        <option value="2">Tuesday</option>
        <option value="3">Wednesday</option>
        <option value="4">Thursday</option>
        <option value="5">Friday</option>
      </select>
    </div>
    <div class="field">
      <label>Overdue after</label>
      <select id="overdueTime">
        <option value="9">09:00</option>
        <option value="12">12:00</option>
        <option value="17" selected>17:00</option>
        <option value="23">End of day</option>
      </select>
    </div>
    <div class="toolbar-spacer"></div>
    <button id="refreshBtn">Refresh</button>
  </div>

  <div id="unmatchedBanner"></div>

  <div class="stats">
    <div class="stat"><div class="stat-label">Fleet</div><div class="stat-num" id="statTotal">—</div><div class="stat-sub">vehicles on register</div></div>
    <div class="stat accent-done"><div class="stat-label">Submitted</div><div class="stat-num" id="statDone">—</div><div class="stat-sub">checks received</div></div>
    <div class="stat accent-warn"><div class="stat-label">Overdue</div><div class="stat-num" id="statOverdue">—</div><div class="stat-sub">past cut-off</div></div>
    <div class="stat accent-alert"><div class="stat-label">Outstanding</div><div class="stat-num" id="statMissing">—</div><div class="stat-sub">not yet submitted</div></div>
    <div class="stat"><div class="stat-label">Unmatched</div><div class="stat-num" id="statUnknown">—</div><div class="stat-sub">unknown names</div></div>
  </div>

  <div class="panel">
    <div class="panel-header">
      <h2>This week&rsquo;s register</h2>
      <div class="meta" id="weekRange"></div>
    </div>
    <div id="currentTable"><div class="loading">Loading submissions…</div></div>
  </div>
</div>

<div class="view" id="view-history">
  <div class="toolbar">
    <div class="field" style="flex:1;min-width:220px;">
      <label>Filter</label>
      <input type="text" id="historyFilter" placeholder="Search by engineer, registration or alias…">
    </div>
    <div class="field">
      <label>Group by</label>
      <select id="historyGroupBy">
        <option value="week">Week</option>
        <option value="engineer">Engineer</option>
        <option value="van">Vehicle</option>
      </select>
    </div>
  </div>
  <div id="historyContent"><div class="loading">Loading history…</div></div>
</div>

<div class="view" id="view-engineers">
  <div class="panel">
    <div class="panel-header">
      <h2>Engineers</h2>
      <button id="addEngineerBtn">+ Add engineer</button>
    </div>
    <div class="panel-body" id="engineersList"><div class="loading">Loading…</div></div>
  </div>
</div>

<div class="view" id="view-fleet">
  <div class="panel">
    <div class="panel-header">
      <h2>Fleet</h2>
      <button id="addVanBtn">+ Add vehicle</button>
    </div>
    <div id="fleetTable"><div class="loading">Loading…</div></div>
  </div>
</div>

<div class="modal-backdrop" id="modalBackdrop">
  <div class="modal" id="modalContent"></div>
</div>


<script>
// PREVIEW STUB - replaces window.fetch with mock responses
const __engineers = [
