  { id: '4', name: 'Tony Pelin', aliases: ['T. Pelin','Tony'] },
  { id: '5', name: 'Chris Cooke', aliases: ['C. Cooke','Chris C'] },
  { id: '6', name: 'Chris Freeman', aliases: ['C. Freeman','Chris F'] },
  { id: '7', name: 'Colby Lunsford', aliases: ['C. Lunsford','Colby'] },
  { id: '8', name: 'David Molloy', aliases: ['D. Molloy','David','Dave'] }
];
const __fleet = [
  { reg: 'LE73 UHX', engineerId: '1' },
  { reg: 'MA72 YPG', engineerId: '2' },
  { reg: 'GX24 NRV', engineerId: '3' },
  { reg: 'LD71 OKB', engineerId: '4' },
  { reg: 'SF23 WMH', engineerId: '5' },
  { reg: 'HX25 CBA', engineerId: '6' },
  { reg: 'KN22 TEL', engineerId: '7' },
  { reg: 'PR24 JVS', engineerId: '8' }
];
const __now = new Date();
function ago(days, hrs=0) {
  const d = new Date(__now);
  d.setDate(d.getDate()-days);
  d.setHours(d.getHours()-hrs);
  return d.toISOString().slice(0,19).replace('T',' ');
}
const __subs = [
  { id: 's1', createdAt: ago(0, 3), reg: 'LE73 UHX', mileage: '65963', submittedName: 'Connor Brady', warningLights: 'Yes', details: 'BRAKE PADS NEED CHANGING ASAP' },
  { id: 's2', createdAt: ago(0, 5), reg: 'MA72 YPG', mileage: '42108', submittedName: 'Ryan Diggens', warningLights: 'No', details: '' },
  { id: 's3', createdAt: ago(0, 7), reg: 'LD71 OKB', mileage: '98201', submittedName: 'T Pelin', warningLights: 'No', details: 'Wiper blades getting worn' },
