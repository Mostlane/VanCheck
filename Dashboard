<script>
const API_BASE = '';
const LS_KEY = 'mostlane_vancheck_prefs_v2';

let state = {
  cutoffDay: 1, overdueTime: 17, activeView: 'current',
  engineers: [], fleet: [], submissions: [],
  lastRefresh: null, matchCache: {}
};

function loadPrefs() {
  try {
    const raw = localStorage.getItem(LS_KEY);
    if (raw) {
      const p = JSON.parse(raw);
      state.cutoffDay = p.cutoffDay ?? 1;
      state.overdueTime = p.overdueTime ?? 17;
    }
  } catch {}
}
function savePrefs() {
  localStorage.setItem(LS_KEY, JSON.stringify({ cutoffDay: state.cutoffDay, overdueTime: state.overdueTime }));
}

function escapeHtml(s) {
  return String(s ?? '').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}
function normaliseReg(r) { return String(r || '').replace(/\\s+/g,'').toUpperCase(); }
function normaliseName(n) { return String(n || '').toLowerCase().replace(/[^a-z0-9 ]/g,'').replace(/\\s+/g,' ').trim(); }

function levenshtein(a, b) {
  a = normaliseName(a); b = normaliseName(b);
  if (a === b) return 0;
  if (!a.length) return b.length;
  if (!b.length) return a.length;
  const dp = Array.from({length: a.length+1}, (_,i) => [i]);
  for (let j=1; j<=b.length; j++) dp[0][j] = j;
  for (let i=1; i<=a.length; i++) {
    for (let j=1; j<=b.length; j++) {
      dp[i][j] = a[i-1] === b[j-1] ? dp[i-1][j-1] : 1 + Math.min(dp[i-1][j], dp[i][j-1], dp[i-1][j-1]);
    }
  }
  return dp[a.length][b.length];
}

function matchEngineer(submittedName, engineers) {
  if (!submittedName) return { match: null, confidence: 0 };
  if (state.matchCache[submittedName] !== undefined) {
    const id = state.matchCache[submittedName];
    return { match: id ? engineers.find(e => e.id === id) : null, confidence: 1 };
  }
  const target = normaliseName(submittedName);
  if (!target) return { match: null, confidence: 0 };
  for (const eng of engineers) {
    if (normaliseName(eng.name) === target) return { match: eng, confidence: 1 };
    for (const a of (eng.aliases || [])) if (normaliseName(a) === target) return { match: eng, confidence: 1 };
  }
  const parts = target.split(' ');
  if (parts.length >= 2) {
    const firstInitial = parts[0], lastName = parts[parts.length - 1];
    for (const eng of engineers) {
      const ep = normaliseName(eng.name).split(' ');
      if (ep.length >= 2) {
        const ef = ep[0], el = ep[ep.length - 1];
        if (el === lastName && (ef[0] === firstInitial[0] || ef === firstInitial)) return { match: eng, confidence: 0.95 };
      }
    }
  }
  if (parts.length >= 1) {
    const lastName = parts[parts.length - 1];
    const surnames = engineers.filter(e => {
      const ep = normaliseName(e.name).split(' ');
      return ep[ep.length - 1] === lastName;
    });
    if (surnames.length === 1) return { match: surnames[0], confidence: 0.85 };
  }
  let best = null, bestDist = Infinity;
  for (const eng of engineers) {
    for (const cand of [eng.name, ...(eng.aliases || [])]) {
      const d = levenshtein(submittedName, cand);
      if (d < bestDist) { bestDist = d; best = eng; }
    }
  }
  const threshold = Math.max(2, Math.floor(target.length * 0.25));
  if (best && bestDist <= threshold) return { match: best, confidence: 1 - (bestDist / Math.max(target.length, 1)) };
  return { match: null, confidence: 0 };
}

function getWeekStart(now = new Date()) {
  const cutoff = parseInt(state.cutoffDay);
  const todayDow = now.getDay() === 0 ? 7 : now.getDay();
  const start = new Date(now);
  start.setHours(0, 0, 0, 0);
  let diff = todayDow - cutoff;
  if (diff < 0) diff += 7;
  start.setDate(start.getDate() - diff);
  return start;
}
function getOverdueMoment(now = new Date()) {
  const start = getWeekStart(now);
  const o = new Date(start);
  o.setHours(parseInt(state.overdueTime), 0, 0, 0);
  return o;
}
function formatDate(d) { return d.toLocaleDateString('en-GB', { weekday:'short', day:'numeric', month:'short' }); }
function formatDateTime(d) { return d.toLocaleString('en-GB', { day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit' }); }
function parseJotformDate(s) { return new Date((s || '').replace(' ', 'T') + 'Z'); }
function formatMileage(m) { return m ? Number(String(m).replace(/\\D/g,'')).toLocaleString('en-GB') + ' mi' : ''; }

async function api(path, opts = {}) {
  const res = await fetch(API_BASE + path, {
    ...opts,
    headers: { 'Content-Type': 'application/json', ...(opts.headers || {}) }
  });
  const data = await res.json().catch(() => ({}));
  if (!res.ok) throw new Error(data.error || ('HTTP ' + res.status));
  return data;
}

async function loadEngineers() { state.engineers = await api('/api/engineers'); }
async function loadFleet() { state.fleet = await api('/api/fleet'); }
async function loadSubmissions() {
  const r = await api('/api/submissions');
  state.submissions = (r.submissions || []).map(s => ({ ...s, createdAtDate: parseJotformDate(s.createdAt) }));
  state.lastRefresh = new Date();
}

function renderCurrent() {
  const now = new Date();
  const weekStart = getWeekStart(now);
  const overdueAt = getOverdueMoment(now);
  const isPastOverdue = now > overdueAt;

  document.getElementById('weekLabel').textContent = 'Week of ' + formatDate(weekStart);
  document.getElementById('weekRange').textContent = 'Cut-off · ' + overdueAt.toLocaleTimeString('en-GB', {hour:'2-digit',minute:'2-digit'});
  document.getElementById('lastRefresh').textContent = state.lastRefresh
    ? 'Updated ' + state.lastRefresh.toLocaleTimeString('en-GB', {hour:'2-digit',minute:'2-digit'}) : '—';

  const thisWeek = state.submissions.filter(s => s.createdAtDate >= weekStart);
  const byReg = {};
  const unmatched = [];
  for (const s of thisWeek) {
    if (s.reg) {
      const k = normaliseReg(s.reg);
      if (!byReg[k] || s.createdAtDate > byReg[k].createdAtDate) byReg[k] = s;
    }
    if (s.submittedName && !matchEngineer(s.submittedName, state.engineers).match) unmatched.push(s);
  }

  const banner = document.getElementById('unmatchedBanner');
  const unique = [...new Set(unmatched.map(s => s.submittedName))];
  if (unique.length) {
    banner.innerHTML = '<div class="banner"><div><strong>Unknown names this week:</strong> ' +
      unique.map(n => escapeHtml(n)).join(', ') +
      ' — assign each to an engineer so they show up correctly.</div>' +
      '<button class="ghost small" onclick="openUnmatchedResolver()">Resolve</button></div>';
  } else banner.innerHTML = '';

  let done = 0, missing = 0, overdue = 0;
  const rows = state.fleet.map(v => {
    const k = normaliseReg(v.reg);
    const sub = byReg[k];
    const assignedEng = v.engineerId ? state.engineers.find(e => e.id === v.engineerId) : null;
    let statusClass, statusLabel, rowClass, actualEng = null, mismatch = false;

    if (sub) {
      done++;
      statusClass = 'done'; statusLabel = 'Submitted'; rowClass = 'row-done';
      const { match } = matchEngineer(sub.submittedName, state.engineers);
      actualEng = match;
      if (assignedEng && match && assignedEng.id !== match.id) mismatch = true;
    } else if (isPastOverdue) {
      overdue++; missing++;
      statusClass = 'overdue'; statusLabel = 'Overdue'; rowClass = 'row-overdue';
    } else {
      missing++;
      statusClass = 'missing'; statusLabel = 'Awaiting'; rowClass = 'row-missing';
    }

    const displayName = actualEng?.name || sub?.submittedName || assignedEng?.name || '—';
    const submittedAt = sub ? formatDateTime(sub.createdAtDate) : '<span class="dash">—</span>';
    const mileage = sub?.mileage ? formatMileage(sub.mileage) : '<span class="dash">—</span>';
    const warningFlag = sub && sub.warningLights && /^(y|yes)$/i.test(String(sub.warningLights).trim());
    const detailsFlag = sub?.details || '';

    return '<tr class="' + rowClass + ' clickable" onclick="openVanHistory(' + JSON.stringify(v.reg).replace(/"/g,'&quot;') + ')">' +
      '<td><span class="reg">' + escapeHtml(v.reg) + '</span></td>' +
      '<td>' +
        '<div class="engineer-name">' + escapeHtml(displayName) + '</div>' +
        (mismatch ? '<div class="engineer-sub">Assigned to ' + escapeHtml(assignedEng.name) + '</div>' : '') +
        (sub && sub.submittedName && actualEng && normaliseName(sub.submittedName) !== normaliseName(actualEng.name)
          ? '<div class="engineer-sub">Submitted as &ldquo;' + escapeHtml(sub.submittedName) + '&rdquo;</div>' : '') +
      '</td>' +
      '<td><span class="status ' + statusClass + '">' + statusLabel + '</span></td>' +
      '<td class="mileage">' + mileage + '</td>' +
      '<td class="timestamp">' + submittedAt + '</td>' +
      '<td>' +
        (warningFlag ? '<div class="flag">⚠ Warning lights on</div>' : '') +
        (detailsFlag ? '<div class="flag-detail">' + escapeHtml(detailsFlag).slice(0,140) + '</div>' : '') +
        (!warningFlag && !detailsFlag ? '<span class="dash">—</span>' : '') +
      '</td>' +
    '</tr>';
  }).join('');

  document.getElementById('currentTable').innerHTML = '<table>' +
    '<thead><tr><th>Vehicle</th><th>Engineer</th><th>Status</th><th>Mileage</th><th>Submitted</th><th>Flags</th></tr></thead>' +
    '<tbody>' + (rows || '<tr><td colspan="6" class="empty">No vans on register — add them in the Fleet tab.</td></tr>') + '</tbody></table>';

  document.getElementById('statTotal').textContent = state.fleet.length;
  document.getElementById('statDone').textContent = done;
  document.getElementById('statOverdue').textContent = overdue;
  document.getElementById('statMissing').textContent = missing;
  document.getElementById('statUnknown').textContent = unique.length;
}

function renderHistory() {
  const filter = document.getElementById('historyFilter').value.toLowerCase();
  const groupBy = document.getElementById('historyGroupBy').value;
  const content = document.getElementById('historyContent');

  const enriched = state.submissions.map(s => {
    const { match } = matchEngineer(s.submittedName, state.engineers);
    return { ...s, engineer: match };
  }).sort((a,b) => b.createdAtDate - a.createdAtDate);

  const filtered = filter ? enriched.filter(s => {
    const t = [s.engineer?.name || '', s.submittedName || '', s.reg || '', ...(s.engineer?.aliases || [])].join(' ').toLowerCase();
    return t.includes(filter);
  }) : enriched;

  if (!filtered.length) {
    content.innerHTML = '<div class="panel"><div class="empty">No submissions match.</div></div>';
    return;
  }

  const renderRow = s => {
    const engName = s.engineer?.name || (s.submittedName ? '⚠ ' + s.submittedName : '—');
    const warn = s.warningLights && /^(y|yes)$/i.test(String(s.warningLights).trim());
    return '<div class="history-row">' +
      '<div class="when">' + formatDateTime(s.createdAtDate) + '</div>' +
      '<div class="what">' +
        '<div class="engineer-name">' + escapeHtml(engName) + '</div>' +
        '<div class="sub-meta">' +
          (s.reg ? '<span class="reg">' + escapeHtml(s.reg) + '</span>' : '') +
          (s.mileage ? '<span class="mileage">' + formatMileage(s.mileage) + '</span>' : '') +
        '</div>' +
        (warn ? '<div class="flag" style="margin-top:6px;">⚠ Warning lights on</div>' : '') +
        (s.details ? '<div class="flag-detail">' + escapeHtml(s.details).slice(0,200) + '</div>' : '') +
      '</div>' +
    '</div>';
  };

  if (groupBy === 'engineer') {
    const groups = {};
    filtered.forEach(s => {
      const k = s.engineer?.name || '⚠ Unmatched: ' + (s.submittedName || 'unknown');
      (groups[k] ||= []).push(s);
    });
    content.innerHTML = Object.keys(groups).sort().map(name => {
      const subs = groups[name];
      const regs = [...new Set(subs.map(s => s.reg).filter(Boolean))];
      return '<div class="panel">' +
        '<div class="panel-header"><h2>' + escapeHtml(name) + '</h2>' +
        '<div class="meta">' + subs.length + ' checks · ' + (regs.length ? regs.length + ' vehicle' + (regs.length>1?'s':'') : '') + '</div></div>' +
        subs.map(renderRow).join('') + '</div>';
    }).join('');
  } else if (groupBy === 'van') {
    const groups = {};
    filtered.forEach(s => { (groups[s.reg || '⚠ No registration'] ||= []).push(s); });
    content.innerHTML = Object.keys(groups).sort().map(reg => {
      return '<div class="panel">' +
        '<div class="panel-header"><h2><span class="reg">' + escapeHtml(reg) + '</span></h2>' +
        '<div class="meta">' + groups[reg].length + ' checks</div></div>' +
        groups[reg].map(renderRow).join('') + '</div>';
    }).join('');
  } else {
    const groups = {};
    filtered.forEach(s => {
      const ws = getWeekStart(s.createdAtDate);
      const k = ws.toISOString().slice(0,10);
      (groups[k] ||= { date: ws, subs: [] }).subs.push(s);
    });
    const keys = Object.keys(groups).sort().reverse();
    content.innerHTML = keys.map(k => {
      const g = groups[k];
      return '<div class="panel">' +
        '<div class="panel-header"><h2>Week of ' + formatDate(g.date) + '</h2>' +
        '<div class="meta">' + g.subs.length + ' submissions</div></div>' +
        g.subs.map(renderRow).join('') + '</div>';
    }).join('');
  }
}

function renderEngineers() {
  const list = document.getElementById('engineersList');
  if (!state.engineers.length) {
    list.innerHTML = '<div class="empty">No engineers yet.</div>';
    return;
  }
  list.innerHTML = state.engineers.map(e => {
    const count = state.submissions.filter(s => matchEngineer(s.submittedName, state.engineers).match?.id === e.id).length;
    return '<div class="engineer-card">' +
      '<div class="engineer-card-top">' +
        '<div style="flex:1;">' +
          '<div class="name">' + escapeHtml(e.name) + '</div>' +
          '<div class="meta">' + count + ' submissions on record</div>' +
          '<div style="margin-top:8px;">' +
            (e.aliases && e.aliases.length
              ? e.aliases.map(a => '<span class="alias-tag">' + escapeHtml(a) +
                '<span class="x" onclick="event.stopPropagation();removeAlias(\\''+e.id+'\\', '+JSON.stringify(a).replace(/"/g,'&quot;')+')">×</span></span>').join('')
              : '<span style="font-size:11.5px;color:var(--ink-soft);font-style:italic;font-family:var(--font-display);">No aliases</span>') +
          '</div>' +
        '</div>' +
        '<div class="btn-group">' +
          '<button class="ghost small" onclick="promptAddAlias(\\''+e.id+'\\')">+ Alias</button>' +
          '<button class="danger-ghost small" onclick="deleteEngineer(\\''+e.id+'\\')">Delete</button>' +
        '</div>' +
      '</div>' +
    '</div>';
  }).join('');
}

async function promptAddAlias(engineerId) {
  const alias = prompt('Add an alias or alternate spelling:');
  if (!alias || !alias.trim()) return;
  await api('/api/engineers/' + engineerId + '/alias', { method: 'POST', body: JSON.stringify({ alias: alias.trim() }) });
  state.matchCache = {};
  await loadEngineers();
  renderAll();
}

async function removeAlias(engineerId, alias) {
  const eng = state.engineers.find(e => e.id === engineerId);
  if (!eng) return;
  eng.aliases = (eng.aliases || []).filter(a => a !== alias);
  await api('/api/engineers/' + engineerId, { method: 'DELETE' });
  const recreated = await api('/api/engineers', { method: 'POST', body: JSON.stringify({ name: eng.name, aliases: eng.aliases }) });
  for (const v of state.fleet) {
    if (v.engineerId === engineerId) {
      v.engineerId = recreated.id;
      await api('/api/fleet', { method: 'POST', body: JSON.stringify(v) });
    }
  }
  state.matchCache = {};
  await loadEngineers();
  await loadFleet();
  renderAll();
}

async function deleteEngineer(engineerId) {
  if (!confirm('Delete this engineer? Their historical submissions will show as unmatched.')) return;
  await api('/api/engineers/' + engineerId, { method: 'DELETE' });
  for (const v of state.fleet) {
    if (v.engineerId === engineerId) {
      v.engineerId = null;
      await api('/api/fleet', { method: 'POST', body: JSON.stringify(v) });
    }
  }
  state.matchCache = {};
  await loadEngineers();
  await loadFleet();
  renderAll();
}

function openAddEngineerModal() {
  openModal('Add engineer',
    '<div class="field"><label>Full name</label><input type="text" id="newEngName" placeholder="e.g. Jamie Smith" autofocus></div>' +
    '<div class="field"><label>Aliases (optional, comma-separated)</label><input type="text" id="newEngAliases" placeholder="e.g. J Smith, Jamie S"></div>' +
    '<div class="modal-intro" style="margin:0;">Common aliases (initials, first name, surname combinations) will be added automatically.</div>',
    async () => {
      const name = document.getElementById('newEngName').value.trim();
      if (!name) return alert('Name required');
      const aliasesStr = document.getElementById('newEngAliases').value.trim();
      const userAliases = aliasesStr ? aliasesStr.split(',').map(a => a.trim()).filter(Boolean) : [];
      const parts = name.split(/\\s+/);
      const autoAliases = [];
      if (parts.length >= 2) {
        const first = parts[0], last = parts[parts.length-1];
        autoAliases.push(first[0] + '. ' + last, first[0] + ' ' + last, first, first + ' ' + last[0] + '.');
      }
      const aliases = [...new Set([...userAliases, ...autoAliases])];
      await api('/api/engineers', { method: 'POST', body: JSON.stringify({ name, aliases }) });
      state.matchCache = {};
      await loadEngineers();
      closeModal();
      renderAll();
    });
}

function renderFleet() {
  const t = document.getElementById('fleetTable');
  if (!state.fleet.length) { t.innerHTML = '<div class="empty">No vehicles yet.</div>'; return; }
  const rows = state.fleet.map(v => {
    const eng = v.engineerId ? state.engineers.find(e => e.id === v.engineerId) : null;
    return '<tr>' +
      '<td><span class="reg">' + escapeHtml(v.reg) + '</span></td>' +
      '<td>' + (eng ? '<span class="engineer-name">' + escapeHtml(eng.name) + '</span>' : '<span class="dash" style="font-style:italic;font-family:var(--font-display);">Unassigned</span>') + '</td>' +
      '<td style="text-align:right;">' +
        '<button class="ghost small" onclick="editVan('+JSON.stringify(v.reg).replace(/"/g,'&quot;')+')">Edit</button> ' +
        '<button class="danger-ghost small" onclick="deleteVan('+JSON.stringify(v.reg).replace(/"/g,'&quot;')+')">Delete</button>' +
      '</td></tr>';
  }).join('');
  t.innerHTML = '<table><thead><tr><th>Registration</th><th>Assigned engineer</th><th></th></tr></thead><tbody>' + rows + '</tbody></table>';
}

function openAddVanModal(existingReg = null) {
  const existing = existingReg ? state.fleet.find(v => normaliseReg(v.reg) === normaliseReg(existingReg)) : null;
  const engOptions = '<option value="">— Unassigned —</option>' +
    state.engineers.map(e => '<option value="' + e.id + '"' + (existing?.engineerId === e.id ? ' selected' : '') + '>' + escapeHtml(e.name) + '</option>').join('');
  openModal(existing ? 'Edit vehicle' : 'Add vehicle',
    '<div class="field"><label>Registration</label><input type="text" id="vanReg" value="' + (existing ? escapeHtml(existing.reg) : '') + '" placeholder="e.g. LE73 UHX"' + (existing ? ' readonly' : ' autofocus') + '></div>' +
    '<div class="field"><label>Assigned engineer</label><select id="vanEngineer">' + engOptions + '</select></div>',
    async () => {
      const reg = document.getElementById('vanReg').value.trim();
      const engineerId = document.getElementById('vanEngineer').value || null;
      if (!reg) return alert('Registration required');
      await api('/api/fleet', { method: 'POST', body: JSON.stringify({ reg, engineerId }) });
      await loadFleet();
      closeModal();
      renderAll();
    });
}
function editVan(reg) { openAddVanModal(reg); }
async function deleteVan(reg) {
  if (!confirm('Remove ' + reg + ' from the fleet?')) return;
  await api('/api/fleet/' + encodeURIComponent(normaliseReg(reg)), { method: 'DELETE' });
  await loadFleet();
  renderAll();
}

function openUnmatchedResolver() {
  const now = new Date();
  const weekStart = getWeekStart(now);
  const thisWeek = state.submissions.filter(s => s.createdAtDate >= weekStart);
  const unmatched = thisWeek.filter(s => s.submittedName && !matchEngineer(s.submittedName, state.engineers).match);
  const unique = [...new Set(unmatched.map(s => s.submittedName))];
  if (!unique.length) return alert('No unmatched names this week.');

  let html = '<div class="modal-intro">For each unknown name, assign it to an existing engineer as an alias, or create a new engineer record.</div>';
  unique.forEach((name, i) => {
    const engOptions = '<option value="">— Choose —</option>' +
      state.engineers.map(e => '<option value="alias:' + e.id + '">Add as alias for ' + escapeHtml(e.name) + '</option>').join('') +
      '<option value="new">+ Create new engineer &ldquo;' + escapeHtml(name) + '&rdquo;</option>';
    let bestSuggest = null, bestDist = Infinity;
    for (const eng of state.engineers) {
      const d = levenshtein(name, eng.name);
      if (d < bestDist) { bestDist = d; bestSuggest = eng; }
    }
    const sugg = bestSuggest && bestDist <= 4
      ? '<div class="suggestion">Closest match · ' + escapeHtml(bestSuggest.name) + ' (edit distance ' + bestDist + ')</div>' : '';
    html += '<div class="resolve-item">' +
      '<div class="unknown-name">&ldquo;' + escapeHtml(name) + '&rdquo;</div>' +
      '<select id="resolve_' + i + '" style="width:100%;padding:8px 12px;border:1px solid var(--rule-strong);border-radius:2px;font-size:13px;font-family:var(--font-body);">' + engOptions + '</select>' +
      sugg + '</div>';
  });

  openModal('Resolve unknown names', html, async () => {
    for (let i = 0; i < unique.length; i++) {
      const choice = document.getElementById('resolve_' + i).value;
      const name = unique[i];
      if (!choice) continue;
      if (choice === 'new') {
        await api('/api/engineers', { method: 'POST', body: JSON.stringify({ name, aliases: [] }) });
      } else if (choice.startsWith('alias:')) {
        await api('/api/engineers/' + choice.slice(6) + '/alias', { method: 'POST', body: JSON.stringify({ alias: name }) });
      }
    }
    state.matchCache = {};
    await loadEngineers();
    closeModal();
    renderAll();
  });
}

function openVanHistory(reg) {
  const key = normaliseReg(reg);
  const subs = state.submissions.filter(s => normaliseReg(s.reg) === key).sort((a,b) => b.createdAtDate - a.createdAtDate);
  let html = '<div class="modal-intro">' + subs.length + ' submissions on record for this vehicle.</div>';
  if (!subs.length) html += '<div class="empty" style="padding:20px 0;">No history.</div>';
  else html += '<div style="margin:0 -26px;">' + subs.map(s => {
    const { match } = matchEngineer(s.submittedName, state.engineers);
    const engName = match?.name || (s.submittedName ? '⚠ ' + s.submittedName : '—');
    const warn = s.warningLights && /^(y|yes)$/i.test(String(s.warningLights).trim());
    return '<div class="history-row">' +
      '<div class="when">' + formatDateTime(s.createdAtDate) + '</div>' +
      '<div class="what">' +
        '<div class="engineer-name">' + escapeHtml(engName) + '</div>' +
        (s.mileage ? '<div class="sub-meta"><span class="mileage">' + formatMileage(s.mileage) + '</span></div>' : '') +
        (warn ? '<div class="flag" style="margin-top:6px;">⚠ Warning lights on</div>' : '') +
        (s.details ? '<div class="flag-detail">' + escapeHtml(s.details).slice(0,200) + '</div>' : '') +
      '</div></div>';
  }).join('') + '</div>';
  openModal(reg + ' · History', html, null, 'Close');
}

function openModal(title, bodyHtml, onSave, okLabel = 'Save') {
  const c = document.getElementById('modalContent');
  c.innerHTML = '<div class="modal-header">' + escapeHtml(title) + '</div>' +
    '<div class="modal-body">' + bodyHtml + '</div>' +
    '<div class="modal-footer">' +
      '<button class="ghost" onclick="closeModal()">' + (onSave ? 'Cancel' : 'Close') + '</button>' +
      (onSave ? '<button id="modalSave">' + okLabel + '</button>' : '') +
    '</div>';
  if (onSave) document.getElementById('modalSave').addEventListener('click', onSave);
  document.getElementById('modalBackdrop').classList.add('open');
}
function closeModal() { document.getElementById('modalBackdrop').classList.remove('open'); }
document.getElementById('modalBackdrop').addEventListener('click', e => { if (e.target.id === 'modalBackdrop') closeModal(); });

document.querySelectorAll('.tab').forEach(t => {
  t.addEventListener('click', () => {
    document.querySelectorAll('.tab').forEach(x => x.classList.remove('active'));
    document.querySelectorAll('.view').forEach(x => x.classList.remove('active'));
    t.classList.add('active');
    state.activeView = t.dataset.view;
    document.getElementById('view-' + state.activeView).classList.add('active');
    renderAll();
  });
});

function renderAll() {
  if (state.activeView === 'current') renderCurrent();
  else if (state.activeView === 'history') renderHistory();
  else if (state.activeView === 'engineers') renderEngineers();
  else if (state.activeView === 'fleet') renderFleet();
}

async function refresh() {
  try {
    document.getElementById('currentTable').innerHTML = '<div class="loading">Loading submissions…</div>';
    await Promise.all([loadEngineers(), loadFleet(), loadSubmissions()]);
    state.matchCache = {};
    renderAll();
  } catch (e) {
    document.getElementById('currentTable').innerHTML = '<div class="error"><strong>Couldn&rsquo;t load:</strong> ' + escapeHtml(e.message) + '</div>';
  }
}

document.getElementById('refreshBtn').addEventListener('click', refresh);
document.getElementById('addEngineerBtn').addEventListener('click', openAddEngineerModal);
document.getElementById('addVanBtn').addEventListener('click', () => openAddVanModal());
document.getElementById('cutoffDay').addEventListener('change', e => { state.cutoffDay = parseInt(e.target.value); savePrefs(); renderAll(); });
document.getElementById('overdueTime').addEventListener('change', e => { state.overdueTime = parseInt(e.target.value); savePrefs(); renderAll(); });
document.getElementById('historyFilter').addEventListener('input', renderHistory);
document.getElementById('historyGroupBy').addEventListener('change', renderHistory);

loadPrefs();
document.getElementById('cutoffDay').value = state.cutoffDay;
document.getElementById('overdueTime').value = state.overdueTime;
refresh();
setInterval(refresh, 5 * 60 * 1000);

window.openUnmatchedResolver = openUnmatchedResolver;
window.openVanHistory = openVanHistory;
window.editVan = editVan;
window.deleteVan = deleteVan;
window.deleteEngineer = deleteEngineer;
window.promptAddAlias = promptAddAlias;
window.removeAlias = removeAlias;
window.closeModal = closeModal;
</script>
</body>
</html>
